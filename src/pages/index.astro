---
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeToggle from "../components/ThemeToggle";

const year = new Date().getFullYear();

const roleSnapshot = ["2025 - Present", "Oslo, Norway", "On site"];

const impactCards = [
  {
    title: "Reliable Support During Important Periods",
    detail: "Contributed technical support for national exams and larger events, helping systems run smoothly.",
  },
  {
    title: "Practical AI Workflow Support",
    detail: "Helped develop AI tools that improved research reporting and reduced repetitive manual work.",
  },
  {
    title: "Day-to-Day Operations",
    detail: "Supported infrastructure, administration, and event technology workflows as part of daily operations.",
  },
];

const currentFocus = [
  {
    title: "Microsoft Azure certification (AZ-900)",
    detail: "Building a stronger cloud foundation by studying core services, identity, governance, and cost-aware architecture.",
  },
  {
    title: "AI in education workflows",
    detail: "Exploring practical AI support for internal tasks and reporting where quality, privacy, and reliability are important.",
  },
  {
    title: "Operational automation",
    detail: "Improving repeatable day-to-day processes with lightweight automation and better technical routines.",
  },
  {
    title: "Communication and documentation",
    detail: "Improving issue handling, handovers, and clear documentation so work is easier to maintain across teams.",
  },
];

const projects = [
  {
    title: "AltKalkis",
    description: "AltKalkis is a customizable utility dashboard that combines calculators and live widgets in one responsive view.",
    url: "https://lbraten.github.io/AltKalkis/",
    github: "https://github.com/lbraten/AltKalkis",
    label: "lbraten.github.io/AltKalkis",
  },
  {
    title: "ScaleSnap",
    description: "ScaleSnap is a web app for measuring distances on images after quick scale calibration.",
    url: "https://lbraten.github.io/ScaleSnap/",
    github: "https://github.com/lbraten/ScaleSnap/",
    label: "lbraten.github.io/ScaleSnap",
  },
  {
    title: "Lavendra Frame",
    description: "Lavendra Frame is a browser-based video editor with timeline tools and local export via FFmpeg WebAssembly.",
    url: "https://lbraten.github.io/Lavendra-Frame/",
    github: "https://github.com/lbraten/Lavendra-Frame/",
    label: "lbraten.github.io/Lavendra-Frame",
  },
  {
    title: "The Component Expert",
    description: "An interactive learning platform designed to help users understand computer components and how they work together.",
    url: "https://lbraten.github.io/Komponenteksperten/",
    github: "https://github.com/lbraten/Komponenteksperten",
    label: "lbraten.github.io/Komponenteksperten",
  },
];
---

<BaseLayout>
  <div class="bg-orb bg-orb--one" data-speed-y="0.05" data-speed-x="0.02" aria-hidden="true"></div>
  <div class="bg-orb bg-orb--two" data-speed-y="-0.035" data-speed-x="-0.015" aria-hidden="true"></div>
  <div class="bg-orb bg-orb--mini-a" data-speed-y="0.02" data-speed-x="-0.03" aria-hidden="true"></div>
  <div class="bg-orb bg-orb--mini-b" data-speed-y="-0.022" data-speed-x="0.018" aria-hidden="true"></div>
  <div class="bg-orb bg-orb--mini-c" data-speed-y="0.03" data-speed-x="0.012" aria-hidden="true"></div>
  <div class="bg-orb bg-orb--mini-d" data-speed-y="-0.018" data-speed-x="-0.02" aria-hidden="true"></div>
  <div class="bg-orb bg-orb--mini-e" data-speed-y="0.014" data-speed-x="0.028" aria-hidden="true"></div>
  <div class="bg-orb bg-orb--mini-f" data-speed-y="-0.026" data-speed-x="-0.01" aria-hidden="true"></div>

  <header class="site-header glass">
    <a class="brand" href="#top" aria-label="Go to top">LB</a>
    <nav class="main-nav" aria-label="Primary">
      <a href="#about">What I Do</a>
      <a href="#projects">Projects</a>
      <a href="#contact">Contact</a>
    </nav>
    <div class="nav-tools" aria-label="Profile links and theme toggle">
      <a class="icon-btn" href="https://github.com/lbraten" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile">
        <i class="fa-brands fa-github" aria-hidden="true"></i>
      </a>
      <a
        class="icon-btn"
        href="https://www.linkedin.com/in/leanderbraaten/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn profile"
      >
        <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
      </a>
      <ThemeToggle client:load />
    </div>
  </header>

  <main id="top">
    <section class="hero container reveal" aria-labelledby="hero-title">
      <p class="eyebrow">Personal Website and Project Portfolio</p>
      <h1 id="hero-title">Technical support, operations, and AI tooling with a practical, steady approach.</h1>
      <p class="hero-copy">
        I am Leander Bråten, an IT operations apprentice with hands-on experience in technical support, system administration,
        AI tool development, and event technology management. I am currently expanding my cloud expertise through
        Microsoft Azure certification (AZ-900).
      </p>
      <div class="hero-actions">
        <a class="btn btn--primary" href="https://portfolio.lbraten.xyz/" target="_blank" rel="noopener noreferrer">
          Visit Portfolio
        </a>
        <a class="btn btn--ghost" href="#contact">Get In Touch</a>
      </div>
      <ul class="hero-highlights" aria-label="Highlights">
        <li>Driving AI innovation in education</li>
        <li>Preparing for Microsoft Azure certification (AZ-900)</li>
        <li>Reliable technical operations for important events and everyday needs</li>
      </ul>
    </section>

    <section id="about" class="container section reveal" aria-labelledby="about-title">
      <div class="section-heading">
        <p class="eyebrow">What I Do</p>
        <h2 id="about-title">IT Operations Apprentice @ Utdanningsdirektoratet (2025 - Present)</h2>
      </div>
      <div class="about-grid">
        <article class="info-card glass-soft">
          <h3>Role Summary</h3>
          <p>
            Oslo, Norway - On site. I provide operational and technical support across events, infrastructure,
            and AI-driven initiatives in the education domain.
          </p>
        </article>
        <article class="info-card glass-soft">
          <h3>Responsibilities</h3>
          <p>
            Manage technical infrastructure for events and conferences, support AI research and development,
            and provide system administration and day-to-day operational support.
          </p>
        </article>
        <article class="info-card glass-soft">
          <h3>Achievements</h3>
          <p>
            Delivered technical support for national exams and large-scale events, and developed AI tools that
            streamlined research reporting.
          </p>
        </article>
      </div>
      <ul class="hero-highlights" aria-label="Tech stack and methods">
        <li>React</li>
        <li>Jira</li>
        <li>Azure</li>
        <li>Copilot Studio</li>
        <li>AI Foundry</li>
        <li>Scrum</li>
      </ul>
    </section>

    <section class="container section reveal" aria-labelledby="snapshot-title">
      <div class="section-heading">
        <p class="eyebrow">Current Role Snapshot</p>
        <h2 id="snapshot-title">IT Operations Apprentice @ Utdanningsdirektoratet</h2>
      </div>
      <div class="snapshot-panel glass-soft">
        <ul class="snapshot-meta" aria-label="Role metadata">
          {
            roleSnapshot.map((item) => (
              <li>{item}</li>
            ))
          }
        </ul>
        <ul class="snapshot-points" aria-label="Current role focus points">
          <li>Manage technical infrastructure for events and conferences.</li>
          <li>Support AI-driven research and development initiatives.</li>
          <li>Provide system administration and operational support.</li>
        </ul>
      </div>
    </section>

    <section class="container section reveal" aria-labelledby="impact-title">
      <div class="section-heading">
        <p class="eyebrow">Key Impact</p>
        <h2 id="impact-title">Examples from my current apprenticeship work.</h2>
      </div>
      <div class="impact-grid" role="list">
        {
          impactCards.map((impact) => (
            <article class="impact-card glass-soft" role="listitem">
              <h3>{impact.title}</h3>
              <p>{impact.detail}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="container section reveal" aria-labelledby="focus-title">
      <div class="section-heading">
        <p class="eyebrow">Current Focus</p>
        <h2 id="focus-title">What I am actively improving in my apprenticeship this year.</h2>
      </div>
      <div class="focus-strip glass-soft" role="list">
        {
          currentFocus.map((focus) => (
            <article class="focus-item" role="listitem">
              <h3>{focus.title}</h3>
              <p>{focus.detail}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="projects" class="container section reveal" aria-labelledby="projects-title">
      <div class="section-heading">
        <p class="eyebrow">Selected Projects</p>
        <h2 id="projects-title">Featured work and tools I have built.</h2>
      </div>
      <div class="project-grid" role="list">
        {
          projects.map((project) => (
            <article class="project-card glass" role="listitem">
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <div class="project-links">
                <a href={project.url} target="_blank" rel="noopener noreferrer">Live Demo</a>
                <a href={project.github} target="_blank" rel="noopener noreferrer">GitHub</a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section id="contact" class="container section section--contact reveal" aria-labelledby="contact-title">
      <div class="contact-card glass">
        <div>
          <p class="eyebrow">Contact</p>
          <h2 id="contact-title">Open to impactful roles and focused client work.</h2>
          <p>
            If you are hiring, staffing a contract, or evaluating product-focused developers, I would be happy to
            connect.
          </p>
        </div>
        <div class="contact-links" aria-label="Contact links">
          <a class="btn btn--primary contact-link" href="mailto:leander.braten.contact@gmail.com">
            <i class="fa-solid fa-at" aria-hidden="true"></i>
            <span>leander.braten.contact@gmail.com</span>
          </a>
          <a
            class="btn btn--ghost contact-link"
            href="https://www.linkedin.com/in/leanderbraaten/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
            <span>LinkedIn</span>
          </a>
          <a class="btn btn--ghost contact-link" href="https://github.com/lbraten" target="_blank" rel="noopener noreferrer">
            <i class="fa-brands fa-github" aria-hidden="true"></i>
            <span>GitHub</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer container">
    <p>© {year} Leander Bråten. Built for clarity and momentum.</p>
  </footer>
</BaseLayout>
